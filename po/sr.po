msgstr "игра;логика;табла;game;logic;board;igra;logika;tabla;"

#: data/org.gnome.Tetravex.gschema.xml.in:12
msgid "The size of the playing grid"
msgstr "Величина мреже за игру"

#: data/org.gnome.Tetravex.gschema.xml.in:16
msgid "Saved game, if any"
msgstr "Сачувана игра, ако постоји"

